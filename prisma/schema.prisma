generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  EDITOR
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(EDITOR)
  createdAt    DateTime @default(now())
}

model Mosque {
  id          String   @id @default(cuid())
  name        String
  location    String
  image       String?
  zuhrJamaat  String
  fajrOnFive  Int
  fajrOffFive Int
  asrGap      Int
  ishaGap     Int
  maghribGap  Int
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
